    {
      "type": "table",
      "title": "⏱ Tiempos por fase de cada predicción",
      "description": "Cada fila es una predicción. La barra horizontal de cada columna muestra cuánto tarda esa fase (más larga = más tiempo).",
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "postgres", "uid": "TriageIA-Postgres"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROW_NUMBER() OVER (ORDER BY inicio_solicitud DESC) AS \"#\", TO_CHAR(inicio_solicitud, 'DD/MM HH24:MI:SS') AS \"Fecha\", ROUND(EXTRACT(EPOCH FROM (fin_preprocesamiento - inicio_preprocesamiento))::numeric, 2)::float AS \"Whisper\", ROUND(EXTRACT(EPOCH FROM (fin_extraccion_entidades - inicio_extraccion_entidades))::numeric, 2)::float AS \"Mistral LLM\", ROUND(EXTRACT(EPOCH FROM (fin_entrenamiento - inicio_entrenamiento))::numeric, 3)::float AS \"ML Orange\", ROUND(EXTRACT(EPOCH FROM (fin_solicitud - inicio_solicitud))::numeric, 2)::float AS \"Total\" FROM entrevista WHERE motor_workflow IN ('Streamlit','API') AND fin_solicitud IS NOT NULL ORDER BY inicio_solicitud DESC LIMIT 50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"}
          },
          "unit": "s"
        },
